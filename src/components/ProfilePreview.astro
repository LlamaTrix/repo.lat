---
import ImagePlaceholder from "./ImagePlaceholder.astro";

const codeLines = [
	'<span class="text-slate-500">&lt;</span><span class="text-fuchsia-400">div</span> <span class="text-emerald-400">class</span>=<span class="text-amber-300">"card"</span><span class="text-slate-500">&gt;</span>',
	'  <span class="text-slate-500">&lt;</span><span class="text-fuchsia-400">img</span> <span class="text-emerald-400">src</span>=<span class="text-amber-300">"{{avatar_github}}"</span> <span class="text-slate-500">/&gt;</span>',
	'  <span class="text-slate-500">&lt;</span><span class="text-fuchsia-400">h1</span><span class="text-slate-500">&gt;</span>{{nombre}}<span class="text-slate-500">&lt;/</span><span class="text-fuchsia-400">h1</span><span class="text-slate-500">&gt;</span>',
	'  <span class="text-slate-500">&lt;</span><span class="text-fuchsia-400">p</span><span class="text-slate-500">&gt;</span>💻 Dev desde LATAM<span class="text-slate-500">&lt;/</span><span class="text-fuchsia-400">p</span><span class="text-slate-500">&gt;</span>',
	'  <span class="text-slate-500">&lt;</span><span class="text-fuchsia-400">div</span> <span class="text-emerald-400">class</span>=<span class="text-amber-300">"stats"</span><span class="text-slate-500">&gt;</span>',
	"    {{repos}} repos · {{stars}} ⭐ · {{lenguaje_top}}",
	'  <span class="text-slate-500">&lt;/</span><span class="text-fuchsia-400">div</span><span class="text-slate-500">&gt;</span>',
	'<span class="text-slate-500">&lt;/</span><span class="text-fuchsia-400">div</span><span class="text-slate-500">&gt;</span>',
];
---

<section class="mx-auto max-w-6xl px-6 py-20">
	<div class="mx-auto mb-14 max-w-2xl text-center" data-reveal>
		<h2 class="text-3xl font-bold text-white sm:text-4xl">Tu HTML, tu perfil</h2>
		<p class="mt-4 text-slate-400">
			Edita el código, mira el resultado. Nada de editores de arrastrar y soltar.
		</p>
	</div>

	<div class="grid overflow-hidden rounded-2xl border border-white/10 lg:grid-cols-2" data-reveal>
		<div class="bg-[#0d0d16]">
			<div class="flex items-center gap-2 border-b border-white/10 px-4 py-3">
				<span class="h-3 w-3 rounded-full bg-red-500/70"></span>
				<span class="h-3 w-3 rounded-full bg-yellow-500/70"></span>
				<span class="h-3 w-3 rounded-full bg-green-500/70"></span>
				<span class="ml-2 text-xs text-slate-500">perfil.html</span>
			</div>
			<pre
				class="overflow-x-auto p-5 text-[13px] leading-relaxed"
				data-code-reveal
			><code>{codeLines.map((line) => (
				<Fragment><span class="block" data-code-line set:html={line} />{"\n"}</Fragment>
			))}</code></pre>
		</div>

		<div class="flex items-center justify-center bg-[radial-gradient(ellipse_80%_60%_at_50%_0%,rgba(16,185,129,0.12),transparent)] p-8">
			<div class="w-full max-w-xs rounded-2xl border border-white/10 bg-white/[0.04] p-6 text-center shadow-2xl">
				<ImagePlaceholder label="Avatar" ratio="aspect-square" class="mx-auto mb-4 h-16 w-16 rounded-xl" />
				<h3 class="font-semibold text-white">Camila Rodríguez</h3>
				<p class="mt-1 text-sm text-slate-400">💻 Dev desde LATAM</p>
				<div class="mt-4 flex justify-center gap-4 text-xs text-slate-300">
					<span class="rounded-full bg-white/5 px-3 py-1">42 repos</span>
					<span class="rounded-full bg-white/5 px-3 py-1">318 ⭐</span>
				</div>
				<p class="mt-4 text-xs text-slate-500">repo.lat/camila</p>
			</div>
		</div>
	</div>
</section>

<script>
	import gsap from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	document.querySelectorAll<HTMLElement>("pre[data-code-reveal]").forEach((group) => {
		if (prefersReducedMotion) return;
		const lines = group.querySelectorAll<HTMLElement>("[data-code-line]");
		gsap.fromTo(
			lines,
			{ opacity: 0, x: -12 },
			{
				opacity: 1,
				x: 0,
				duration: 0.35,
				ease: "power2.out",
				stagger: 0.08,
				scrollTrigger: { trigger: group, start: "top 75%" },
			}
		);
	});
</script>
