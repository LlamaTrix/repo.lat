---
const rows = [
	{ feature: "URL propia y compartible", repolat: true, readme: false, linkedin: false },
	{ feature: "HTML/CSS 100% personalizable", repolat: true, readme: false, linkedin: false },
	{ feature: "Datos sincronizados desde GitHub", repolat: true, readme: "parcial", linkedin: false },
	{ feature: "Gratis y open source", repolat: true, readme: true, linkedin: false },
	{ feature: "Pensado para developers LATAM", repolat: true, readme: false, linkedin: false },
];

function renderCell(value: boolean | string) {
	if (value === true) return "✅";
	if (value === false) return "—";
	return value;
}
---

<section class="mx-auto max-w-5xl px-6 py-20">
	<div class="mx-auto mb-14 max-w-2xl text-center" data-reveal>
		<h2 class="text-3xl font-bold text-white sm:text-4xl">¿Por qué no solo un README?</h2>
		<p class="mt-4 text-slate-400">
			repo.lat no reemplaza tu GitHub, lo complementa con una vitrina que sí puedes moldear.
		</p>
	</div>

	<div class="overflow-x-auto rounded-2xl border border-white/10" data-reveal>
		<table class="w-full min-w-[560px] border-collapse text-sm">
			<thead>
				<tr class="border-b border-white/10 text-left text-slate-400">
					<th class="p-4 font-medium">Funcionalidad</th>
					<th class="p-4 text-center font-medium text-white">repo.lat</th>
					<th class="p-4 text-center font-medium">README de GitHub</th>
					<th class="p-4 text-center font-medium">LinkedIn</th>
				</tr>
			</thead>
			<tbody>
				{rows.map((row, i) => (
					<tr class={i % 2 === 0 ? "bg-white/[0.02]" : ""}>
						<td class="p-4 text-slate-300">{row.feature}</td>
						<td class="p-4 text-center text-white">{renderCell(row.repolat)}</td>
						<td class="p-4 text-center text-slate-400">{renderCell(row.readme)}</td>
						<td class="p-4 text-center text-slate-400">{renderCell(row.linkedin)}</td>
					</tr>
				))}
			</tbody>
		</table>
	</div>
</section>
