---
import ImagePlaceholder from "./ImagePlaceholder.astro";
---

<section class="relative overflow-hidden px-6 pt-20 pb-24">
	<div
		id="hero-glow-1"
		class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(ellipse_60%_50%_at_50%_-10%,rgba(168,85,247,0.25),transparent)]"
	>
	</div>
	<div
		class="pointer-events-none absolute inset-0 -z-10 bg-[linear-gradient(to_right,rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:56px_56px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,black,transparent)]"
	>
	</div>

	<div class="mx-auto max-w-4xl text-center" data-reveal>
		<div
			class="mx-auto mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-medium text-slate-300"
		>
			<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-400"></span>
			Open source · hecho por la comunidad LATAM
		</div>

		<h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl md:text-6xl">
			Tu perfil de dev,
			<span
				class="bg-gradient-to-r from-emerald-400 via-cyan-400 to-fuchsia-400 bg-clip-text text-transparent"
			>
				directo desde GitHub
			</span>
		</h1>

		<p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400">
			Conecta tu cuenta de GitHub, generamos tu perfil de programador al instante
			(repos, lenguajes, contribuciones) y lo personalizas con tu propio HTML y CSS.
			Sin plantillas rígidas, sin vendor lock-in: es tuyo, es open source, es de
			Latinoamérica.
		</p>

		<div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
			<a
				href="#conectar"
				class="w-full rounded-full bg-gradient-to-r from-emerald-400 to-fuchsia-400 px-7 py-3.5 text-sm font-bold text-[#0a0a12] transition hover:opacity-90 sm:w-auto"
			>
				Conectar con GitHub
			</a>
			<a
				href="https://github.com/LlamaTrix/repo.lat"
				class="w-full rounded-full border border-white/15 px-7 py-3.5 text-sm font-semibold text-white transition hover:bg-white/5 sm:w-auto"
			>
				⭐ Ver código en GitHub
			</a>
		</div>
	</div>

	<div class="mx-auto mt-16 max-w-5xl" data-reveal>
		<ImagePlaceholder label="Captura del dashboard de repo.lat" ratio="aspect-[16/9]" />
	</div>
</section>

<script>
	const glow = document.getElementById("hero-glow-1");
	window.addEventListener(
		"scroll",
		() => {
			if (!glow) return;
			const offset = Math.min(window.scrollY * 0.15, 80);
			glow.style.transform = `translateY(${offset}px)`;
		},
		{ passive: true }
	);
</script>
