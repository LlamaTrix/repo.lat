---
const year = new Date().getFullYear();

const columns = [
	{
		title: "Producto",
		links: [
			{ label: "Características", href: "#caracteristicas" },
			{ label: "Cómo funciona", href: "#como-funciona" },
			{ label: "Preguntas frecuentes", href: "#preguntas" },
		],
	},
	{
		title: "Comunidad",
		links: [
			{ label: "Código en GitHub", href: "https://github.com/LlamaTrix/repo.lat" },
			{ label: "Reportar un problema", href: "https://github.com/LlamaTrix/repo.lat/issues" },
			{ label: "Contribuir", href: "https://github.com/LlamaTrix/repo.lat/pulls" },
		],
	},
];
---

<footer class="border-t border-white/5 px-6 py-14">
	<div class="mx-auto grid max-w-6xl gap-10 sm:grid-cols-[1.5fr_1fr_1fr]">
		<div>
			<p class="flex items-center gap-2 text-lg font-bold text-white">
				<span class="text-emerald-400">&lt;/&gt;</span>
				repo<span class="text-fuchsia-400">.lat</span>
			</p>
			<p class="mt-3 max-w-xs text-sm text-slate-400">
				Perfiles de desarrollador conectados a GitHub, con HTML 100% personalizable.
				Open source, hecho por la comunidad de Latinoamérica.
			</p>
		</div>

		{columns.map((col) => (
			<div>
				<h4 class="mb-3 text-sm font-semibold text-white">{col.title}</h4>
				<ul class="space-y-2">
					{col.links.map((link) => (
						<li>
							<a href={link.href} class="text-sm text-slate-400 transition hover:text-white">
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</div>
		))}
	</div>

	<div class="mx-auto mt-10 max-w-6xl border-t border-white/5 pt-6 text-center text-sm text-slate-500">
		Hecho con 💚 por la comunidad LATAM · {year}
	</div>
</footer>
