---
import { Image } from "astro:assets";
import latamCode from "../assets/images/latam-code.png";

const steps = [
	{ number: "01", title: "Conecta GitHub", description: "Autorizas acceso de lectura a tu información pública. Nada de contraseñas ni permisos de escritura." },
	{ number: "02", title: "Elige qué contar", description: "Ordena tus proyectos, destaca el trabajo que te representa y oculta el ruido." },
	{ number: "03", title: "Dale tu forma", description: "Parte de una base sólida o escribe tu propio HTML y CSS mientras ves el resultado." },
	{ number: "04", title: "Compártelo", description: "Pon el enlace en tu CV, tus redes o ese mensaje que acompaña una postulación." },
];
---
<section id="como-funciona" class="mx-auto max-w-6xl px-6 py-24">
	<div class="grid gap-14 lg:grid-cols-[.8fr_1.2fr]">
		<div data-reveal><p class="mb-3 text-xs font-semibold uppercase tracking-[.2em] text-fuchsia-300">De repositorios a relato</p><h2 class="text-3xl font-bold text-white sm:text-5xl">Tu trabajo ya existe. Solo hace falta ponerlo en orden.</h2><Image src={latamCode} alt="Computadora, perfiles y mapa de Latinoamérica" class="mt-8 hidden w-full max-w-sm drop-shadow-2xl lg:block" width={500} loading="lazy" /></div>
		<div class="space-y-4">{steps.map((step) => <article class="grid grid-cols-[3.5rem_1fr] gap-5 rounded-2xl border border-white/10 bg-white/[.025] p-6" data-reveal><span class="text-sm font-bold text-emerald-300">{step.number}</span><div><h3 class="text-lg font-semibold text-white">{step.title}</h3><p class="mt-2 text-sm leading-relaxed text-slate-400">{step.description}</p></div></article>)}</div>
	</div>
</section>
