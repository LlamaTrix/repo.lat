---
const steps = [
	{
		number: "01",
		title: "Conecta tu GitLab",
		description: "Inicia sesión con OAuth. No pedimos contraseñas, solo permiso de lectura.",
	},
	{
		number: "02",
		title: "Generamos tu perfil",
		description:
			"Repos, stats de contribución y actividad reciente, listos en una página propia al instante.",
	},
	{
		number: "03",
		title: "Personaliza y comparte",
		description:
			"Edita el HTML/CSS de tu perfil como quieras y comparte tu link con el mundo.",
	},
];
---

<section id="como-funciona" class="mx-auto max-w-6xl px-6 py-20">
	<div class="mx-auto mb-14 max-w-2xl text-center">
		<h2 class="text-3xl font-bold text-white sm:text-4xl">Cómo funciona</h2>
		<p class="mt-4 text-slate-400">Tres pasos, sin fricción.</p>
	</div>

	<div class="grid gap-8 md:grid-cols-3">
		{steps.map((step, i) => (
			<div class="relative">
				<span
					class="mb-4 block bg-gradient-to-r from-emerald-400 to-fuchsia-400 bg-clip-text text-5xl font-extrabold text-transparent"
				>
					{step.number}
				</span>
				<h3 class="mb-2 text-lg font-semibold text-white">{step.title}</h3>
				<p class="text-sm leading-relaxed text-slate-400">{step.description}</p>

				{i < steps.length - 1 && (
					<div class="absolute top-6 left-full hidden h-px w-8 bg-gradient-to-r from-white/20 to-transparent md:block"></div>
				)}
			</div>
		))}
	</div>
</section>
