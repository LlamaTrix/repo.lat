---
import ImagePlaceholder from "./ImagePlaceholder.astro";

const steps = [
	{
		number: "01",
		title: "Conecta tu GitHub",
		description:
			"Inicia sesión con OAuth. No pedimos contraseñas, solo permiso de lectura sobre tu perfil público.",
	},
	{
		number: "02",
		title: "Importamos tu actividad",
		description:
			"Repos, lenguajes más usados, commits recientes y contribuciones, listos en tu perfil al instante.",
	},
	{
		number: "03",
		title: "Personaliza el HTML",
		description:
			"Edita el HTML/CSS de tu perfil en un editor en vivo. Sin límites de plantilla, es tu código.",
	},
	{
		number: "04",
		title: "Comparte tu URL",
		description:
			"Tu perfil vive en repo.lat/tu-usuario. Ponlo en tu CV, LinkedIn o bio de redes.",
	},
];
---

<section id="como-funciona" class="mx-auto max-w-6xl px-6 py-20">
	<div class="mx-auto mb-14 max-w-2xl text-center" data-reveal>
		<h2 class="text-3xl font-bold text-white sm:text-4xl">Cómo funciona</h2>
		<p class="mt-4 text-slate-400">Cuatro pasos, sin fricción.</p>
	</div>

	<div class="grid gap-10 md:grid-cols-2">
		{steps.map((step, i) => (
			<div class="flex gap-5" data-reveal style={`transition-delay: ${(i % 2) * 100}ms`}>
				<ImagePlaceholder label={`Paso ${step.number}`} ratio="aspect-square" class="h-20 w-20 shrink-0" />
				<div>
					<span
						class="mb-1 block bg-gradient-to-r from-emerald-400 to-fuchsia-400 bg-clip-text text-2xl font-extrabold text-transparent"
					>
						{step.number}
					</span>
					<h3 class="mb-2 text-lg font-semibold text-white">{step.title}</h3>
					<p class="text-sm leading-relaxed text-slate-400">{step.description}</p>
				</div>
			</div>
		))}
	</div>
</section>
