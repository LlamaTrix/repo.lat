---
interface Props {
	label?: string;
	class?: string;
	ratio?: string;
}

const { label = "Imagen", class: className = "", ratio = "aspect-video" } = Astro.props;
---

<div
	class:list={[
		"group relative flex items-center justify-center overflow-hidden rounded-xl border border-dashed border-white/15 bg-[linear-gradient(135deg,rgba(255,255,255,0.04)_25%,transparent_25%,transparent_50%,rgba(255,255,255,0.04)_50%,rgba(255,255,255,0.04)_75%,transparent_75%,transparent)] bg-[length:16px_16px]",
		ratio,
		className,
	]}
>
	<div class="flex flex-col items-center gap-2 text-slate-500">
		<svg viewBox="0 0 24 24" class="h-8 w-8 fill-current opacity-60">
			<path
				d="M4 5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H4Zm0 2h16v7.59l-3.3-3.3a1 1 0 0 0-1.4 0L11 15.59l-2.3-2.3a1 1 0 0 0-1.4 0L4 16.59V7Zm3 1.5A1.5 1.5 0 1 0 7 11.5 1.5 1.5 0 0 0 7 8.5Z"
			></path>
		</svg>
		<span class="text-xs font-medium">{label}</span>
	</div>
</div>
