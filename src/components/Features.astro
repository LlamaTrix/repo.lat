	share: "M13 5.5a3.5 3.5 0 1 1 1.06 2.5l-6.19 3.5a3.5 3.5 0 0 1 0 1l6.19 3.5a3.5 3.5 0 1 1-.98 1.74l-6.19-3.5a3.5 3.5 0 1 1 0-4.48l6.19-3.5A3.5 3.5 0 0 1 13 5.5Z",
