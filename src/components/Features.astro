	heart:
		"M12 21s-6.7-4.35-9.33-8.2C.9 10.24 1.4 6.9 4.2 5.3c2.2-1.25 4.7-.6 6.1 1.2.5.65.9 1.3 1.7 1.3s1.2-.65 1.7-1.3c1.4-1.8 3.9-2.45 6.1-1.2 2.8 1.6 3.3 4.94 1.53 7.5C18.7 16.65 12 21 12 21Z",
