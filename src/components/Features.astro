---

<section id="caracteristicas" class="mx-auto max-w-6xl px-6 py-20">
	<div class="mx-auto mb-14 max-w-2xl text-center" data-reveal>
		<h2 class="text-3xl font-bold text-white sm:text-4xl">Todo lo que necesitas para brillar</h2>
		<p class="mt-4 text-slate-400">
			Un perfil de desarrollador que refleja tu trabajo real, no una plantilla genérica.
		</p>
	</div>

	<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-group>
		{features.map((feature) => (
			<div
				class="tilt-card rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition-colors hover:border-white/20 hover:bg-white/[0.05]"
				data-reveal-item
			>
				<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-emerald-400/20 to-fuchsia-400/20">
					<svg viewBox="0 0 24 24" class="h-5 w-5 fill-emerald-400">
						<path d={icons[feature.icon]}></path>
					</svg>
				</div>
				<h3 class="mb-2 font-semibold text-white">{feature.title}</h3>
				<p class="text-sm leading-relaxed text-slate-400">{feature.description}</p>
			</div>
		))}
	</div>
</section>
