---
const profiles = [
	{ name: "Vale Ríos", role: "Frontend developer", place: "Cochabamba, BO", style: "minimal", accent: "#5eead4", projects: ["Tinku UI", "Ruta abierta"] },
	{ name: "Nico Ferreira", role: "Backend & data", place: "Montevideo, UY", style: "terminal", accent: "#a3e635", projects: ["mate-cli", "datos.uy"] },
	{ name: "Luna Campos", role: "Creative coder", place: "Medellín, CO", style: "creative", accent: "#f472b6", projects: ["Jardín digital", "Luz común"] },
	{ name: "Rafa Melo", role: "Product engineer", place: "Recife, BR", style: "editorial", accent: "#fbbf24", projects: ["Maré", "Caderno"] },
];
---

<section id="perfiles" class="mx-auto max-w-6xl px-6 py-24">
	<div class="mb-12 max-w-2xl" data-reveal>
		<p class="mb-3 text-xs font-semibold uppercase tracking-[.2em] text-emerald-300">Un perfil, muchas voces</p>
		<h2 class="text-3xl font-bold tracking-tight text-white sm:text-5xl">No todos programamos igual. Nuestros perfiles tampoco deberían verse igual.</h2>
		<p class="mt-5 text-slate-400">Estos son ejemplos ficticios hechos con los mismos datos que repo.lat puede importar desde GitHub.</p>
	</div>

	<div class="grid gap-6 sm:grid-cols-2" data-reveal-group>
		{profiles.map((profile, index) => (
			<article class:list={["profile-example tilt-card overflow-hidden rounded-2xl border border-white/10", `profile-${profile.style}`]} style={`--accent:${profile.accent}`} data-reveal-item>
				<div class="flex min-h-[310px] flex-col p-7">
					<div class="flex items-start justify-between">
						<div class="grid h-12 w-12 place-items-center rounded-full border border-white/15 bg-white/10 text-sm font-bold" style={`color:${profile.accent}`}>{profile.name.split(" ").map((word) => word[0]).join("")}</div>
						<span class="text-xs text-white/45">0{index + 1} / perfil</span>
					</div>
					<div class="mt-auto">
						<p class="mb-2 text-xs" style={`color:${profile.accent}`}>{profile.place}</p>
						<h3 class="text-3xl font-bold text-white">{profile.name}</h3>
						<p class="mt-1 text-sm text-white/60">{profile.role}</p>
						<div class="mt-6 grid grid-cols-2 gap-3">
							{profile.projects.map((project) => <div class="rounded-lg border border-white/10 bg-black/20 px-3 py-3 text-xs text-white/75">{project}<span class="mt-2 block h-px w-8" style={`background:${profile.accent}`}></span></div>)}
						</div>
					</div>
				</div>
			</article>
		))}
	</div>
</section>

<style>
	.profile-example{background:#10101a}.profile-minimal{background:linear-gradient(145deg,#f1f5f1,#dce5df);color:#102019}.profile-minimal h3,.profile-minimal [class*="text-white"]{color:#142019}.profile-minimal [class*="white/"]{border-color:rgba(15,35,25,.15)}
	.profile-terminal{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;background:linear-gradient(145deg,#07110c,#0c2116)}
	.profile-creative{background:radial-gradient(circle at 90% 10%,#ec489955,transparent 35%),radial-gradient(circle at 10% 90%,#06b6d455,transparent 40%),#171021}
	.profile-editorial{background:linear-gradient(110deg,#191919 65%,#7c2d12)}
</style>
