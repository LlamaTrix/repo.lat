---
import ImagePlaceholder from "./ImagePlaceholder.astro";

const examples = [
	{
		title: "Minimalista",
		description: "Tipografía limpia, mucho espacio en blanco, foco en tus proyectos.",
	},
	{
		title: "Terminal / hacker",
		description: "Estética de consola, fuente monoespaciada, cursor parpadeante.",
	},
	{
		title: "Colorido y creativo",
		description: "Gradientes, animaciones CSS y un toque muy personal.",
	},
	{
		title: "Estilo CV / corporativo",
		description: "Ideal para compartir en procesos de reclutamiento.",
	},
];
---

<section class="mx-auto max-w-6xl px-6 py-20">
	<div class="mx-auto mb-14 max-w-2xl text-center" data-reveal>
		<h2 class="text-3xl font-bold text-white sm:text-4xl">Inspírate con otros perfiles</h2>
		<p class="mt-4 text-slate-400">
			Como el HTML es tuyo, tu perfil puede verse exactamente como quieras. Algunas ideas:
		</p>
	</div>

	<div class="grid gap-6 sm:grid-cols-2" data-reveal-group>
		{examples.map((example) => (
			<div class="tilt-card" data-reveal-item>
				<ImagePlaceholder label={example.title} ratio="aspect-[4/3]" />
				<h3 class="mt-4 font-semibold text-white">{example.title}</h3>
				<p class="mt-1 text-sm text-slate-400">{example.description}</p>
			</div>
		))}
	</div>
</section>
