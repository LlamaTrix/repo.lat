---
const navLinks = [
	{ href: "#caracteristicas", label: "Características" },
	{ href: "#como-funciona", label: "Cómo funciona" },
	{ href: "#preguntas", label: "Preguntas" },
	{ href: "https://github.com/LlamaTrix/repo.lat", label: "GitHub" },
];
---

<header
	id="site-header"
	class="sticky top-0 z-50 border-b border-white/5 bg-[#0a0a12]/80 py-4 backdrop-blur-md transition-[padding] duration-300"
>
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6">
		<a href="#" class="flex items-center gap-2 text-lg font-bold text-white">
			<span class="text-emerald-400">&lt;/&gt;</span>
			repo<span class="text-fuchsia-400">.lat</span>
		</a>

		<nav class="hidden items-center gap-8 text-sm font-medium text-slate-300 md:flex">
			{navLinks.map((link) => (
				<a href={link.href} class="transition-colors hover:text-white">
					{link.label}
				</a>
			))}
		</nav>

		<a
			href="#conectar"
			class="magnetic-btn flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-semibold text-[#0a0a12] transition hover:bg-slate-200"
		>
			<svg viewBox="0 0 24 24" class="h-4 w-4 fill-current">
				<path
					d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-1.04-.01-1.89-2.78.62-3.37-1.21-3.37-1.21-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.89 1.57 2.34 1.11 2.91.85.09-.67.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.31.1-2.72 0 0 .84-.28 2.75 1.05a9.34 9.34 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.46.1 2.72.64.72 1.03 1.63 1.03 2.75 0 3.93-2.34 4.79-4.57 5.05.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.81 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"
				></path>
			</svg>
			Conectar con GitHub
		</a>
	</div>
</header>
